{
  "dependencies": {
    "bootstrap": "5.3.8",
    "content-disposition-header": "^0.6.0",
    "datatables.net-bs5": "^2.3.8",
    "datatables.net-plugins": "^2.3.6",
    "esbuild": "^0.28.0",
    "fabric": "^5.5.2",
    "luxon": "^3.7.2",
    "tom-select": "^2.6.0",
    "utif2": "^4.1.0"
  },
  "scripts": {
    "collectstatic": "./manage.py collectstatic --noinput",
    "build-css": "esbuild ./client/src/app.css --bundle --minify --sourcemap --outfile=./client/dist/app.css",
    "build-js": "esbuild ./client/src/app.js --bundle --minify --sourcemap --outfile=./client/dist/app.js",
    "build": "npm run build-js && npm run build-css && npm run collectstatic",
    "lint": "semistandard --fix client/ && stylelint client/src/*.css",
    "test": "tape client/tests/test_*.js",
    "coverage": "c8 -o staticfiles/clientcov/ -n 'client/src/**/*.js' npm test && c8 report -o staticfiles/clientcov/ -r html -n 'client/src/**/*.js'",
    "end": ""
  },
  "type": "module",
  "devDependencies": {
    "c8": "^11.0.0",
    "jsdom": "^29.0.2",
    "semistandard": "^17.0.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "tape": "^5.9.0"
  }
}
