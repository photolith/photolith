#: photolith/templates/annotate/annotate.html
msgid "Copy full annotation"
msgstr "Afrita aldursmerkingu"

#: photolith/templates/annotate/annotate.html
msgid "Copy axis line only"
msgstr "Afrita lestrarás"

#: photolith/templates/annotate/annotate.html
msgid "Delete annotation"
msgstr "Eyða aldursmerkingu"

#: photolith/templates/annotate/annotate.html
msgid ""
"Annuli will be added/moved freeform. Pressing <kbd>Ctrl</kbd> will add/move "
"along axis"
msgstr ""
"Aldursmerkingar munu ekki fylgja ekki lestrarás. Með því að ýta á <kbd>Ctrl</"
"kbd> er hægt að láta merkingarnar fylgja lestrarásnum."

#: photolith/templates/annotate/annotate.html
msgid "Free-form"
msgstr "Aldursmerkingar fylgja ekki lestarás"

#: photolith/templates/annotate/annotate.html
msgid ""
"Annuli will be added/moved along axis. Pressing <kbd>Ctrl</kbd> will add/"
"move freeform"
msgstr ""
"Aldursmerkingum er bætt á og fylgja lestrarás. Með því að ýta á <kbd>Ctrl</"
"kbd> er hægt að færa þær frá ásnum með því að draga þær til eða tvíklikka "
"fjarri ás til að búa til nýja merkingu."

#: photolith/templates/annotate/annotate.html
msgid "Snap to axis"
msgstr "Merkingar læsast við lestrarás"

#: photolith/templates/annotate/annotate.html
msgid "Save as general annotation"
msgstr "Vista aldursmerkingu í gagnagrunn"

#: photolith/templates/annotate/annotate.html
#: photolith/templates/ingest/index.html
#: photolith/templates/project/update.html
