#: photolith/templates/annotate/annotate.html
msgid "Annotate by marking the otolith/rings in the image."
msgstr "Settu inn ár með því að tvísmella á árhring á myndinni."

#: photolith/templates/annotate/annotate.html
msgid "Then fill in the <kbd>Annotate</kbd> form and press <kbd>Save</kbd>."
msgstr ""
"Fylltu svo út <kbd>aldursmerkingarformið</kbd> og ýttu á <kbd>Vista</kbd>"

#: photolith/templates/annotate/annotate.html
#: photolith/templates/ingest/index.html
msgid "You can:"
msgstr "Þú getur"

#: photolith/templates/annotate/annotate.html
#: photolith/templates/ingest/index.html
msgid "Zoom in/out by pinching or scrolling the mouse"
msgstr "Þysjaðu inn/út með því að skrolla með músinni"

#: photolith/templates/annotate/annotate.html
msgid ""
"Adjust image contrast or download using the magic wand menu, increasing ring "
"detail by decreasing gamma, e.g."
msgstr ""
"Breyttu contrast, gamma o.þ.h. með því að ýta á galdrasprotann á myndinni."
"Breyting á Gamma og/eða Contrast getur aukið smáatriði á myndinni."

#: photolith/templates/annotate/annotate.html
msgid "Drag the start and end points to mark the centre & edge of the otolith"
msgstr ""
"Dragðu upphafs- og endapunkta á ásnum til að merkja miðju og jaðar kvarnar"

#: photolith/templates/annotate/annotate.html
msgid ""
"Double-click on the line to add a ring marker, drag a ring marker to move it"
msgstr ""
"Tvíklikkaðu á ásinn til að bæta við aldurslestri eða dragðu merkinguna til "
"að færa hana til"

#: photolith/templates/annotate/annotate.html
msgid "Double-click a ring marker to remove"
msgstr "Tvíklikkaðu á merkingu til að fjarlægja hana"

#: photolith/templates/annotate/annotate.html
msgid ""
"<kbd>Ctrl</kbd>-drag to move a ring marker freeform, not following the axis "
"line"
msgstr ""
"Smelltu með vinstri takka á músinni og haltu inni Ctlr til að færa merkingu "
"án þess að fylgja ásinum."

